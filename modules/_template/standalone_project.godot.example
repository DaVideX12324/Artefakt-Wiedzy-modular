; Example standalone project file for this module.
; Do not name this file project.godot while the module lives inside the host project.
; Godot ignores nested folders that contain another project.godot.
;
; To run this module standalone, copy the module folder outside the host project
; and rename this file to project.godot there.

config_version=5

[application]

config/name="Template Module"
run/main_scene="res://scenes/module_entry_standalone.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

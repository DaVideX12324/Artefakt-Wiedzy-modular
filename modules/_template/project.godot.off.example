; Standalone runner for a module copied outside the host project.
; While the module lives inside Artefakt Wiedzy modular, keep this file as .off.

config_version=5

[application]

config/name="Template Module"
run/main_scene="res://module_root.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
